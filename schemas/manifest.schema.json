{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "manifest.schema.json",
  "title": "Skill Registry Manifest",
  "description": "Schema for skill-registry manifest.json",
  "type": "object",
  "required": ["registryType", "namespace", "version", "channel", "generatedAt", "items"],
  "properties": {
    "registryType": {
      "type": "string",
      "const": "skill"
    },
    "namespace": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "$ref": "https://raw.githubusercontent.com/skillinterop/registry-hub/main/schemas/shared/common.schema.json#/definitions/SemanticVersion"
    },
    "channel": {
      "$ref": "https://raw.githubusercontent.com/skillinterop/registry-hub/main/schemas/shared/common.schema.json#/definitions/Channel"
    },
    "generatedAt": {
      "$ref": "https://raw.githubusercontent.com/skillinterop/registry-hub/main/schemas/shared/common.schema.json#/definitions/ISODateTime"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ManifestItem"
      }
    }
  },
  "definitions": {
    "ManifestItem": {
      "type": "object",
      "required": ["canonicalId", "name", "version", "description", "path", "channel", "status", "deprecatedBy", "metadata"],
      "properties": {
        "canonicalId": {
          "type": "string",
          "pattern": "^skill/[^/]+/[a-z0-9][a-z0-9-]*@[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "name": {
          "$ref": "https://raw.githubusercontent.com/skillinterop/registry-hub/main/schemas/shared/common.schema.json#/definitions/KebabCaseName"
        },
        "version": {
          "$ref": "https://raw.githubusercontent.com/skillinterop/registry-hub/main/schemas/shared/common.schema.json#/definitions/SemanticVersion"
        },
        "description": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "channel": {
          "$ref": "https://raw.githubusercontent.com/skillinterop/registry-hub/main/schemas/shared/common.schema.json#/definitions/Channel"
        },
        "status": {
          "$ref": "https://raw.githubusercontent.com/skillinterop/registry-hub/main/schemas/shared/common.schema.json#/definitions/ItemStatus"
        },
        "deprecatedBy": {
          "type": ["string", "null"]
        },
        "metadata": {
          "type": "object"
        }
      }
    }
  }
}
